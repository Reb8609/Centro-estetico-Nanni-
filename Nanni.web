    <!-- JavaScript -->
    <script>
        function setLanguage(lang) {
            document.cookie = "googtrans=/it/" + lang + "; path=/";
            document.cookie = "googtrans=/it/" + lang + "; domain=." + document.domain + "; path=/";
            window.location.reload();
        }

        function updateLanguageUI() {
            const match = document.cookie.match(/(?:^|;)\s*googtrans=([^;]*)/);
            let currentLang = 'it';
            if (match && match[1]) {
                const parts = match[1].split('/');
                if (parts.length > 2) currentLang = parts[2];
            }
            
            const langLabel = document.getElementById('current-lang-label');
            const langLabelMobile = document.getElementById('current-lang-label-mobile');
            if (langLabel) langLabel.innerText = currentLang.toUpperCase();
            if (langLabelMobile) langLabelMobile.innerText = currentLang.toUpperCase();
        }

        function navigate(event, pageId) {
            event.preventDefault();
            
            const allPages = document.querySelectorAll('.page-section');
            allPages.forEach(page => {
                page.classList.remove('block');
                page.classList.add('hidden');
            });
            
            const targetPage = document.getElementById('page-' + pageId);
            targetPage.classList.remove('hidden');
            targetPage.classList.add('block');
            
            const menu = document.getElementById('mobile-menu');
            menu.classList.add('hidden');
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function toggleMobileMenu() {
            const menu = document.getElementById('mobile-menu');
            if (menu.classList.contains('hidden')) {
                menu.classList.remove('hidden');
            } else {
                menu.classList.add('hidden');
            }
        }
        
        function toggleLangMenuMobile() {
            const langMenu = document.getElementById('mobile-lang-menu');
            if (langMenu.classList.contains('hidden')) {
                langMenu.classList.remove('hidden');
            } else {
                langMenu.classList.add('hidden');
            }
        }

        window.addEventListener('scroll', function() {
            const navbar = document.getElementById('navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('shadow-md');
                navbar.classList.remove('shadow-sm');
            } else {
                navbar.classList.remove('shadow-md');
                navbar.classList.add('shadow-sm');
            }
        });

        window.addEventListener('load', function() {
            updateLanguageUI(); 

            setTimeout(() => {
                const popup = document.getElementById('promo-popup');
                const content = document.getElementById('promo-content');
                
                popup.classList.remove('hidden');
                popup.classList.add('flex');
                
                void popup.offsetWidth; 
                
                popup.classList.remove('opacity-0');
                popup.classList.add('opacity-100');
                
                content.classList.remove('scale-95');
                content.classList.add('scale-100');
            }, 1500); 
        });

        function closePromoPopup() {
            const popup = document.getElementById('promo-popup');
            const content = document.getElementById('promo-content');
            
            popup.classList.remove('opacity-100');
            popup.classList.add('opacity-0');
            
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
            
            setTimeout(() => {
                popup.classList.add('hidden');
                popup.classList.remove('flex');
            }, 500); 
        }
    </script>
